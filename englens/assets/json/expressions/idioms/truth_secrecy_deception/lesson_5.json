      "img": "",
      "pronunciation": "ɪn nˈeɪm ˈoʊnli",
      "senses": [
        {
          "definition": "used for saying that a person, thing, situation etc. is not actually like what their description, label, or title suggests",
          "examples": [
            {
              "cf": "",
              "x": "The organization was democratic in name only, as the actual decision-making power rested with a single individual."
            },
            {
              "cf": "",
              "x": "The honorary title of \"ambassador\" was given to him, but he was an ambassador in name alone, lacking any diplomatic duties or responsibilities."
            },
            {
              "cf": "",
              "x": "The company provided employee benefits on paper, but they were benefits in name only, with numerous restrictions and limitations."
            },
            {
              "cf": "",
              "x": "The political party claimed to support equality, but it was egalitarian in name alone, as its policies favored the privileged few."
            },
            {
              "cf": "",
              "x": "The committee had a diverse membership in name only, with token representation but little meaningful inclusion or participation."
            }
          ]
        }
      ]

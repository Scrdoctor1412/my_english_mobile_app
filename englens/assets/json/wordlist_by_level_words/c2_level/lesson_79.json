      "phonetic": "https://tts.langeek.co/read?text=ZmVtdXI&hash=a6cf3fee7184ecaf6d8510d2a1e5bfa6e4710eba&lang=en&cache-only=0",
      "phonetic_text": "fi:mər",
      "phonetic_am": "https://tts.langeek.co/read?text=ZmVtdXI&hash=a6cf3fee7184ecaf6d8510d2a1e5bfa6e4710eba&lang=en&cache-only=0",
      "phonetic_am_text": "feemēr",
      "img": "",
      "senses": [
        {
          "definition": "(anatomy) the longest bone in the top part of the human leg between the hip and the knee",
          "examples": [
            {
              "cf": "",
              "x": "The femur is the longest and strongest bone in the human body, extending from the hip to the knee."
            },
            {
              "cf": "",
              "x": "A fracture of the femur can result from severe trauma, such as a car accident or a significant fall, and often requires surgical repair."
            },
            {
              "cf": "",
              "x": "The head of the femur fits into the hip socket, forming the hip joint, which allows for a wide range of leg movements."
            },
            {
              "cf": "",
              "x": "Osteoporosis can weaken the femur, making it more susceptible to fractures, especially in older adults."
            },
            {
              "cf": "",
              "x": "The femur plays a crucial role in supporting the weight of the body and enabling activities such as walking, running, and jumping."
            }
          ]
        }
      ]

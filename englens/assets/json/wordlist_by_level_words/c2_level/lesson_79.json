    {
      "word": "esophagus",
      "pos": "noun",
      "phonetic": "https://tts.langeek.co/read?text=ZXNvcGhhZ3Vz&hash=08b0381fcf1ea5e55fb4bc36b94e7ca5919fd6a0&lang=en&cache-only=0",
      "phonetic_text": "ɪsɑ:fəgəs",
      "phonetic_am": "https://tts.langeek.co/read?text=ZXNvcGhhZ3Vz&hash=08b0381fcf1ea5e55fb4bc36b94e7ca5919fd6a0&lang=en&cache-only=0",
      "phonetic_am_text": "isaafēgēs",
      "img": "",
      "senses": [
        {
          "definition": "a muscular tube that connects the throat to the stomach, allowing for the passage of food and liquids during digestion",
          "examples": [
            {
              "cf": "",
              "x": "The esophagus is a muscular tube that connects the throat to the stomach, allowing food and liquids to pass from the mouth to the stomach for digestion."
            },
            {
              "cf": "",
              "x": "When you swallow food or drink, it travels down the esophagus through a series of muscle contractions called peristalsis."
            },
            {
              "cf": "",
              "x": "Disorders of the esophagus, such as gastroesophageal reflux disease (GERD) or esophageal cancer, can cause symptoms like heartburn, difficulty swallowing, or chest pain."
            },
            {
              "cf": "",
              "x": "The lower esophageal sphincter (LES) is a ring of muscle at the bottom of the esophagus that opens to let food into the stomach and closes to prevent stomach acid from coming back up into the esophagus."
            },
            {
              "cf": "",
              "x": "A blockage or narrowing of the esophagus, called esophageal stricture, can make it difficult or painful to swallow food or liquids."
            }
          ]
        }
      ]
    },

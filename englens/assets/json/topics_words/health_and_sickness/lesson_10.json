      "phonetic_am_text": "haipēkaandriē",
      "img": "",
      "pronunciation": "ˌhaɪpəˈkɑndɹiə",
      "senses": [
        {
          "definition": "a mental condition in which a person is constantly anxious and worried about their health",
          "examples": [
            {
              "cf": "",
              "x": "Individuals with hypochondria may constantly check their bodies for signs of illness, research medical conditions online, and seek reassurance from doctors, friends, or family members about their health."
            },
            {
              "cf": "",
              "x": "Treatment for hypochondria typically involves cognitive-behavioral therapy (CBT) to help individuals challenge and change their distorted beliefs about health and illness."
            },
            {
              "cf": "",
              "x": "People with hypochondria may experience significant distress and impairment in their daily lives due to their preoccupation with health concerns."
            },
            {
              "cf": "",
              "x": "Support from mental health professionals, as well as education about the nature of hypochondria and its treatment options, can help individuals with this condition manage their symptoms and improve their quality of life."
            }
          ]
        }
      ]
    },

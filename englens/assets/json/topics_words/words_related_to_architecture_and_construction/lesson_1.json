            {
              "cf": "",
              "x": "The medieval castle was fortified with thick walls and sturdy buttresses, protecting it from enemy attacks."
            },
            {
              "cf": "",
              "x": "The Romanesque church featured exterior buttresses adorned with decorative carvings, adding to the architectural beauty of the building."
            },
            {
              "cf": "",
              "x": "The Gothic revival mansion had ornamental buttresses that added a sense of drama and verticality to its façade, evoking the spirit of medieval architecture."
            }
          ]
        }

      "phonetic": "https://tts.langeek.co/read?text=YWJhY3Vz&hash=e2db7ce7913459478da52181ff79ddc781041d9f&lang=en&cache-only=0",
      "phonetic_text": "æ.bə.kəs",
      "phonetic_am": "https://tts.langeek.co/read?text=YWJhY3Vz&hash=e2db7ce7913459478da52181ff79ddc781041d9f&lang=en&cache-only=0",
      "phonetic_am_text": "ā.bē.kēs",
      "img": "",
      "pronunciation": "ˈæbəkəs",
      "senses": [
        {
          "definition": "a flat, stone block that sits on top of a column, used to support the parts above it such as a roof",
          "examples": [
            {
              "cf": "",
              "x": "In classical architecture, the abacus is the flat slab that sits atop a column's capital, providing a stable platform for the entablature above."
            },
            {
              "cf": "",
              "x": "The Ionic order is characterized by its distinctive volutes and decorated abacus, adding elegance to the column's design."
            },
            {
              "cf": "",
              "x": "The abacus of the Corinthian capital is adorned with acanthus leaves and scrolls, reflecting the order's ornate style."
            },
            {
              "cf": "",
              "x": "The abacus of the Doric capital is plain and square, in keeping with the order's simpler and more robust aesthetic."
            },
            {
              "cf": "",
              "x": "The abacus serves as a transition element between the column and the entablature, providing structural support while also adding visual interest to the overall composition."
            }
          ]
        }
      ]
    },

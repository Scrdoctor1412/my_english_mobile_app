      "phonetic_am_text": "freskow",
      "img": "",
      "senses": [
        {
          "definition": "a technique of mural painting that is done by putting watercolor on wet plaster on a wall or ceiling",
          "examples": [
            {
              "cf": "",
              "x": "The cathedral's walls were adorned with magnificent frescoes depicting scenes from biblical stories, their vibrant colors still vivid after centuries."
            },
            {
              "cf": "",
              "x": "The artist spent months working on the fresco, carefully applying layers of watercolor onto wet plaster to create a seamless and enduring masterpiece."
            },
            {
              "cf": "",
              "x": "The Renaissance masters were renowned for their skill in fresco painting, using the technique to decorate churches, palaces, and public buildings with scenes of myth, history, and religion."
            },
            {
              "cf": "",
              "x": "The restoration team carefully repaired the damaged fresco, delicately matching the original colors and textures to preserve the artwork's integrity."
            },
            {
              "cf": "",
              "x": "Visitors marveled at the frescoes adorning the walls of the ancient villa, marveling at the skill and artistry of the painters who had created them centuries ago."
            }
          ]
        }

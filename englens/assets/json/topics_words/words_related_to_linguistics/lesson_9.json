      "senses": [
        {
          "definition": "(grammar) a form of a verb that functions as a noun and is formed by adding the suffix -ing to the base form of the verb",
          "examples": [
            {
              "cf": "",
              "x": "A gerund is a verb form that functions as a noun, ending in \"-ing.\""
            },
            {
              "cf": "",
              "x": "Examples of gerunds include \"swimming,\" \"reading,\" and \"writing.\""
            },
            {
              "cf": "",
              "x": "Gerunds can serve as subjects, objects, or complements in a sentence."
            },
            {
              "cf": "",
              "x": "In the sentence \"Running is my favorite hobby,\" \"running\" functions as the subject and is a gerund."
            },
            {
              "cf": "",
              "x": "Gerunds are used to express actions or activities in a general or abstract sense, rather than as specific instances of action."
            }
          ]
        }
      ]
    }
